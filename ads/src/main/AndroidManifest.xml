<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- sdk-kotlin's own HTTP: /preload, /init, /error.
         ACCESS_NETWORK_STATE + com.google.android.gms.permission.AD_ID
         are declared by KontextKit/android and auto-merge into the
         consuming app — see KontextKit/android/src/main/AndroidManifest.xml. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application>
        <activity
            android:name=".ui.InterstitialAdActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen" />
    </application>
</manifest>
